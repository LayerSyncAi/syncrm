# Convex Configuration
# Get your deployment URL from https://dashboard.convex.dev
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Convex Auth (set via `npx @convex-dev/auth` command)
# These are automatically configured when you run the auth setup
# CONVEX_AUTH_PRIVATE_KEY=... (generated automatically)
# CONVEX_AUTH_APPLICATION_ID=... (generated automatically)

# Google Maps API Key (for location typeahead search)
# Get your key from https://console.cloud.google.com/apis/credentials
# Enable "Places API" and "Maps JavaScript API" in your Google Cloud project
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
