# Convex Configuration
# Get your deployment URL from https://dashboard.convex.dev
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Public base URL of the deployed app, no trailing slash. Used to build the
# absolute "add to calendar" links in reminder emails. Must also be set in the
# Convex deployment environment (the reminder cron runs there).
SITE_URL=http://localhost:3000

# Convex Auth (set via `npx @convex-dev/auth` command)
# These are automatically configured when you run the auth setup
# CONVEX_AUTH_PRIVATE_KEY=... (generated automatically)
# CONVEX_AUTH_APPLICATION_ID=... (generated automatically)

# Email (Resend) — required for reminder emails, password resets, etc.
# Get your API key from https://resend.com (format: re_...)
RESEND_API_KEY=
# Sender address — must use a domain verified in Resend (SPF/DKIM/DMARC) so
# Gmail accepts the message. Do not change without verifying the new domain.
EMAIL_FROM="Syncrm<admin@accesshealthcare.co.zw>"

# Reminder catch-up cap, in minutes. After downtime, the per-minute reminder
# job will still send reminders whose due time was missed up to this far in
# the past, but no older — so a long outage can't blast stale reminders for
# events that already started. Set in the Convex deployment env. Default: 60.
REMINDER_MAX_CATCHUP_MINUTES=60

# Google Maps API Key (for location typeahead search)
# Get your key from https://console.cloud.google.com/apis/credentials
# Enable "Places API" and "Maps JavaScript API" in your Google Cloud project
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# OpenAI — required for SynCRM Copilot (server-side only; never expose to the client)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Web Push (PWA notifications)
#
# Generate a keypair once with:  npx web-push generate-vapid-keys
#
# The PUBLIC key is exposed to the browser (inlined at build time) and must be
# byte-identical to VAPID_PUBLIC_KEY in the Convex deployment env, or the
# subscriptions the browser creates cannot be sent to.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
#
# Set these THREE in the CONVEX deployment env (npx convex env set NAME VALUE),
# NOT here — the private key must never reach the browser bundle:
#   VAPID_PUBLIC_KEY   = same value as NEXT_PUBLIC_VAPID_PUBLIC_KEY above
#   VAPID_PRIVATE_KEY  = the private key from the generate step
#   VAPID_SUBJECT      = a mailto: or https: contact URL, e.g. mailto:admin@yourdomain.com

# ─────────────────────────────────────────────────────────────────────────────
# White-label / Branding  (see src/config/brand.ts and docs/BRANDING.md)
#
# Every value below is OPTIONAL. Unset = the SynCRM defaults shown here, so the
# app is identical out of the box. To rebrand a client, set these in .env.local
# (and in the Vercel project's Environment Variables) and redeploy.
#
# NOTE: NEXT_PUBLIC_* are inlined at BUILD time — changes need a rebuild/redeploy.
# ─────────────────────────────────────────────────────────────────────────────

# Identity
NEXT_PUBLIC_BRAND_NAME="SynCRM"
NEXT_PUBLIC_BRAND_LEGAL_NAME="SynCRM"
NEXT_PUBLIC_BRAND_TAGLINE="The CRM built for real estate teams"
NEXT_PUBLIC_BRAND_DESCRIPTION="Real Estate Pipeline CRM"
NEXT_PUBLIC_BRAND_APP_DOMAIN="app.syncrm.com"

# Contact (optional; not rendered by default — available for footers/legal pages)
NEXT_PUBLIC_BRAND_CONTACT_EMAIL=""
NEXT_PUBLIC_BRAND_CONTACT_PHONE=""
NEXT_PUBLIC_BRAND_CONTACT_ADDRESS=""

# Colours (hex). primary = accent; sidebar = nav surface. Glow/row-hover derive
# from primary automatically. surfaces/status tints live in the design system.
NEXT_PUBLIC_BRAND_COLOR_PRIMARY="#eca400"
NEXT_PUBLIC_BRAND_COLOR_PRIMARY_600="#d89500"
NEXT_PUBLIC_BRAND_COLOR_PRIMARY_FG="#ffffff"
NEXT_PUBLIC_BRAND_COLOR_SIDEBAR="#2a5925"
NEXT_PUBLIC_BRAND_COLOR_SIDEBAR_HOVER="#1e3f1a"
NEXT_PUBLIC_BRAND_COLOR_SIDEBAR_FG="#fcfcfc"
NEXT_PUBLIC_BRAND_COLOR_BACKGROUND="#f1f4f9"
NEXT_PUBLIC_BRAND_COLOR_FOREGROUND="#1f2a44"
NEXT_PUBLIC_BRAND_COLOR_SUCCESS="#16a34a"
NEXT_PUBLIC_BRAND_COLOR_WARNING="#ca8a04"
NEXT_PUBLIC_BRAND_COLOR_DANGER="#dc2626"
NEXT_PUBLIC_BRAND_COLOR_INFO="#0284c7"

# Logo asset paths (drop the files in public/brand/ with these names, or point
# these at any /public path). og.png is the social-share image.
NEXT_PUBLIC_BRAND_LOGO_FAVICON="/brand/favicon-32x32.png"
NEXT_PUBLIC_BRAND_LOGO_ICON="/brand/icon-192x192.png"
NEXT_PUBLIC_BRAND_LOGO_APPLE="/brand/apple-touch-icon.png"
NEXT_PUBLIC_BRAND_LOGO_WORDMARK="/brand/wordmark.png"
NEXT_PUBLIC_BRAND_LOGO_OG="/brand/og.png"
